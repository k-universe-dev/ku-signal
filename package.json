{
  "name": "@ku/signal",
  "version": "0.1.0",
  "description": "KU-Signal — K-Universe agent coordination engine",
  "type": "module",
  "bin": {
    "ku-signal": "./bin/ku-signal.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "verify": "tsx scripts/verify.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "execa": "^9.3.0",
    "glob": "^11.0.0",
    "ink": "^5.0.1",
    "openai": "^4.65.0",
    "react": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "homepage": "https://github.com/k-universe-dev/ku-signal",
  "repository": {
    "type": "git",
    "url": "https://github.com/k-universe-dev/ku-signal.git"
  },
  "license": "MIT"
}
